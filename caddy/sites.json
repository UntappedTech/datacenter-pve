[
    {
        "domains": [
            "old-homelab-domain.org",
            "legacy-cluster-site.net"
        ],
        "redirect_to": "example-homelab.com"
    },
    {
        "domains": [
            "example-homelab.com",
            "example-homelab.net"
        ],
        "log": true,
        "fallback_handler": [
            "import global_security_headers",
            "import caching",
            "import serve_html /srv/example-homelab/default"
        ],
        "services": {
            "heimdall-dashboard": {
                "enabled": true,
                "hostnames": [
                    "dashboard",
                    "portal"
                ],
                "import": [
                    "caching",
                    "serve_php /srv/heimdall"
                ]
            },
            "home-assistant": {
                "enabled": true,
                "hostnames": [
                    "homeassistant",
                    "ha"
                ],
                "proxy_target": {
                    "protocol": "https://",
                    "host_address": "192.168.1.100",
                    "port": 8123
                },
                "import": [
                    "proxy_opts_tls_skip"
                ]
            },
            "adguard-home": {
                "enabled": true,
                "hostnames": [
                    "adguard",
                    "dns"
                ],
                "proxy_target": {
                    "host_address": "192.168.1.101",
                    "port": 3000
                },
                "import": [
                    "proxy_opts_default"
                ]
            },
            "jellyfin": {
                "enabled": true,
                "hostnames": [
                    "jellyfin",
                    "watch",
                    "stream",
                    "media"
                ],
                "proxy_target": {
                    "protocol": "http://",
                    "host_address": "192.168.1.102",
                    "port": 8096
                }
            },
            "scrypted-nvr": {
                "enabled": true,
                "hostnames": [
                    "scrypted",
                    "cams"
                ],
                "proxy_target": {
                    "protocol": "https://",
                    "host_address": "192.168.1.103",
                    "port": 10443
                },
                "import": [
                    "proxy_opts_tls_skip"
                ]
            },
            "uptime-kuma": {
                "enabled": false,
                "hostnames": [
                    "uptime",
                    "status"
                ],
                "proxy_target": {
                    "host_address": "192.168.1.104",
                    "port": 3001
                },
                "import": [
                    "proxy_opts_default"
                ]
            },
            "immich-photos-ipv6": {
                "enabled": true,
                "hostnames": [
                    "immich",
                    "photos"
                ],
                "proxy_target": {
                    "host_address": "2001:db8:85a3::8a2e:370:7334",
                    "port": 2283
                }
            },
            "overseerr-requests-ipv6-naked": {
                "enabled": true,
                "hostnames": [
                    "overseerr",
                    "request"
                ],
                "proxy_target": {
                    "host_address": "2001:db8:85a3::8a2e:370:7335"
                }
            },
            "pve-node-proxy": {
                "enabled": true,
                "hostnames": [
                    "pve"
                ],
                "proxy_target": {
                    "protocol": "https://",
                    "host_address": "pve-node-01.local",
                    "port": 8006
                },
                "import": [
                    "proxy_opts_tls_skip"
                ]
            },
            "custom-block-handler": {
                "enabled": true,
                "hostnames": [
                    "assets",
                    "static-files"
                ],
                "handler": [
                    "root * /srv/example-homelab/assets",
                    "encode zstd",
                    "file_server"
                ]
            },
            "stealth-service-no-logs": {
                "enabled": true,
                "log": false,
                "hostnames": [
                    "stealth"
                ],
                "proxy_target": {
                    "host_address": "192.168.1.110",
                    "port": 9000
                }
            }
        }
    }
]